# =============================================================================
# Directory SaaS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development                    # development | test | production
APP_PORT=3333                           # Port the backend listens on
APP_NAME=Directory SaaS                 # Application display name
API_PREFIX=api/v1                       # Global API route prefix

# -----------------------------------------------------------------------------
# Database [REQUIRED]
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://directory:directory_secret@localhost:5432/directory_saas?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret             # Leave empty if no auth

# -----------------------------------------------------------------------------
# JWT Authentication [REQUIRED]
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production-use-a-long-random-string-at-least-32-chars
JWT_EXPIRATION=15m                      # Access token TTL
JWT_REFRESH_SECRET=change-me-in-production-use-a-different-long-random-string-32
JWT_REFRESH_EXPIRATION=7d               # Refresh token TTL

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -----------------------------------------------------------------------------
# MinIO / S3 File Storage
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_secret
S3_BUCKET=directory-saas
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Meilisearch
# -----------------------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=meili_master_key

# -----------------------------------------------------------------------------
# Email (SMTP) — Mailpit for development
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@directory-saas.local

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60                         # Window in seconds
THROTTLE_LIMIT=100                      # Max requests per window

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=log                           # error | warn | log | debug | verbose

# -----------------------------------------------------------------------------
# AI (optional)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
