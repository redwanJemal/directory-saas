# =============================================================================
# Directory SaaS — Test Environment
# =============================================================================
# Overrides for the test environment. Used when NODE_ENV=test.

NODE_ENV=test
APP_PORT=3334
APP_NAME=Directory SaaS Test

# Test database (separate from development)
DATABASE_URL=postgresql://directory:directory_secret@localhost:5432/directory_saas_test?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# JWT (short-lived for faster tests)
JWT_SECRET=test-jwt-secret-that-is-at-least-32-characters-long
JWT_EXPIRATION=5m
JWT_REFRESH_SECRET=test-jwt-refresh-secret-at-least-32-characters-long
JWT_REFRESH_EXPIRATION=1d

# CORS
CORS_ORIGINS=http://localhost:3000

# Lower rate limits for tests
THROTTLE_TTL=60
THROTTLE_LIMIT=1000

# Logging
LOG_LEVEL=error
