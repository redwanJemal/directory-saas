# =============================================================================
# Directory SaaS — Docker Environment Variables
# Copy to .env and update values for your environment
# =============================================================================

# PostgreSQL
POSTGRES_USER=directory
POSTGRES_PASSWORD=directory_secret        # CHANGE in production
POSTGRES_DB=directory_saas
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_secret               # CHANGE in production
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret          # CHANGE in production
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Meilisearch
MEILI_MASTER_KEY=meili_master_key         # CHANGE in production
MEILI_PORT=7700

# Mailpit (dev email — not used in production)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# =============================================================================
# Production-only (docker-compose.coolify.yml)
# =============================================================================

# API
API_PORT=3000
LOG_LEVEL=info

# Frontend ports (Coolify routes via Traefik, these are internal)
WEB_PORT=3010
PROVIDER_PORT=3011
ADMIN_PORT=3012

# Auth — MUST change in production
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret

# CORS — comma-separated origins
CORS_ORIGINS=*

# S3 / MinIO
S3_BUCKET=directory-saas
S3_REGION=us-east-1

# SMTP (production mail server)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@directory.local
