{
  "name": "directory-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant directory SaaS platform",
  "scripts": {
    "dev:backend": "cd backend && npm run start:dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:provider": "cd apps/provider-portal && npm run dev",
    "dev:admin": "cd apps/admin && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build:provider": "cd apps/provider-portal && npm run build",
    "build:admin": "cd apps/admin && npm run build",
    "test:backend": "cd backend && npm test",
    "docker:up": "cd docker && docker compose up -d",
    "docker:down": "cd docker && docker compose down",
    "docker:logs": "cd docker && docker compose logs -f",
    "prisma:generate": "cd backend && npx prisma generate",
    "prisma:migrate": "cd backend && npx prisma migrate dev",
    "prisma:seed": "cd backend && npx prisma db seed"
  }
}
